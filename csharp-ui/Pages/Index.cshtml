@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

@* Add an empty form to the page to generate the anti-forgery token *@
@Html.AntiForgeryToken()

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>

<div class="container mt-5">
    <h2>Best Time to Buy or Sell Stock</h2>
    <form id="stockForm" class="mb-3">
        <div class="mb-3">
            <label for="pricesInput" class="form-label">Enter prices (comma-separated):</label>
            <input type="text" class="form-control" id="pricesInput" placeholder="e.g. 7,1,5,3,6,4" required />
        </div>
        <button type="submit" class="btn btn-primary">Calculate</button>
        <button type="button" id="weatherBtn" class="btn btn-secondary ms-2">Get Weather Forecast</button>
    </form>
    <div id="result" class="alert alert-info d-none"></div>
    <div id="weatherResult" class="alert alert-info d-none mt-3"></div>
</div>

<script>
    document.getElementById('weatherBtn').addEventListener('click', async function () {
        const weatherDiv = document.getElementById('weatherResult');
        weatherDiv.classList.add('d-none');
        weatherDiv.textContent = '';
        try {
            const url = `?handler=WeatherForecast`;
            const response = await fetch(url, {
                method: 'GET',
                headers: {
                    'Accept': 'application/json'
                }
            });
            if (!response.ok) {
                throw new Error('API error: ' + response.status);
            }
            const data = await response.json();
            weatherDiv.textContent = JSON.stringify(data, null, 2);
            weatherDiv.classList.remove('d-none');
        } catch (err) {
            weatherDiv.textContent = 'Error: ' + err.message;
            weatherDiv.classList.remove('d-none');
        }
    });
    document.getElementById('stockForm').addEventListener('submit', async function (e) {
        e.preventDefault();
        const pricesStr = document.getElementById('pricesInput').value;
        const pricesArr = pricesStr.split(',').map(x => parseInt(x.trim(), 10)).filter(x => !isNaN(x));
        const resultDiv = document.getElementById('result');
        resultDiv.classList.add('d-none');
        resultDiv.textContent = '';

        if (!pricesArr.length) {
            resultDiv.textContent = 'Please enter at least one valid price.';
            resultDiv.classList.remove('d-none');
            return;
        }

        try {
            const url = `?handler=BestTimeToBuyOrSellStock`;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ Prices: pricesArr })
            });
            
            if (!response.ok) {
                throw new Error('API error: ' + response.status);
            }
            const data = await response.json();
            resultDiv.textContent = 'Best profit: ' + data;
            resultDiv.classList.remove('d-none');
        } catch (err) {
            resultDiv.textContent = 'Error: ' + err.message;
            resultDiv.classList.remove('d-none');
        }
    });
</script>
